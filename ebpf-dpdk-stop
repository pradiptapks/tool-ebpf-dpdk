#!/bin/bash
# -*- mode: sh; indent-tabs-mode: nil; sh-basic-offset: 4 -*-
# vim: autoindent tabstop=4 shiftwidth=4 expandtab softtabstop=4 filetype=bash

TOOL_OUTPUT_DIR=$(pwd)

echo "tool-ebpf-dpdk: stop: TOOL_OUTPUT_DIR=${TOOL_OUTPUT_DIR}"

STATUS_FILE="${TOOL_OUTPUT_DIR}/ebpf-dpdk-status.txt"
if [ -f "${STATUS_FILE}" ]; then
    status=$(cat "${STATUS_FILE}")
    if [ "${status}" == "no-pmd-threads-found" ]; then
        echo "tool-ebpf-dpdk: stop: no PMD threads were found during start, nothing to stop"
        exit 0
    fi
fi

PID_FILE="${TOOL_OUTPUT_DIR}/ebpf-dpdk-perf-pid.txt"

if [ -f "${PID_FILE}" ]; then
    PERF_PID=$(cat "${PID_FILE}")
    echo "tool-ebpf-dpdk: stop: perf PID=${PERF_PID}"

    if kill -0 "${PERF_PID}" 2>/dev/null; then
        echo "tool-ebpf-dpdk: stop: sending SIGINT to perf (PID ${PERF_PID})"
        kill -s SIGINT "${PERF_PID}"

        for i in $(seq 1 30); do
            if ! kill -0 "${PERF_PID}" 2>/dev/null; then
                echo "tool-ebpf-dpdk: stop: perf exited after ${i}s"
                break
            fi
            sleep 1
        done

        if kill -0 "${PERF_PID}" 2>/dev/null; then
            echo "tool-ebpf-dpdk: stop: force killing perf (PID ${PERF_PID})"
            kill -9 "${PERF_PID}"
            sleep 1
        fi
    else
        echo "tool-ebpf-dpdk: stop: perf PID ${PERF_PID} not running"
    fi
    rm -f "${PID_FILE}"
else
    echo "tool-ebpf-dpdk: stop: PID file not found at ${PID_FILE}"
fi

echo "tool-ebpf-dpdk: stop: directory contents after stop:"
ls -la "${TOOL_OUTPUT_DIR}/" 2>&1

if [ -f "${TOOL_OUTPUT_DIR}/perf.data" ]; then
    PERF_DATA_SIZE=$(stat --format=%s "${TOOL_OUTPUT_DIR}/perf.data" 2>/dev/null || echo 0)
    echo "tool-ebpf-dpdk: stop: perf.data size: ${PERF_DATA_SIZE} bytes"

    if [ "${PERF_DATA_SIZE}" -gt 0 ]; then
        echo "tool-ebpf-dpdk: stop: running perf archive"
        cd "${TOOL_OUTPUT_DIR}" && /usr/bin/perf archive perf.data 2>&1 || true

        echo "tool-ebpf-dpdk: stop: compressing perf.data"
        xz --threads=0 "${TOOL_OUTPUT_DIR}/perf.data"
        echo "tool-ebpf-dpdk: stop: compression complete"
    else
        echo "tool-ebpf-dpdk: stop: WARNING: perf.data is empty (0 bytes)"
    fi
else
    echo "tool-ebpf-dpdk: stop: WARNING: perf.data not found"
fi

echo "tool-ebpf-dpdk: stop: final directory contents:"
ls -la "${TOOL_OUTPUT_DIR}/" 2>&1
echo "stopped" > "${STATUS_FILE}"
